---
import { Picture } from 'astro:assets';
import MePicture from '@/assets/images/me.jpg';
---

<section class="who-section">
    <div class="who-section-picture">
        <Picture
            class="transition-filter h-full w-full scale-100 object-cover grayscale duration-700 ease-in-out hover:scale-105 hover:grayscale-0"
            src={MePicture}
            alt="Me"
            layout="constrained"
            formats={['avif', 'webp']}
            loading="eager"
        />
    </div>
    <div class="who-section-content">
        <h2 class="text-fg-subtle text-base font-bold uppercase md:text-lg">
            Qui suis-je
        </h2>
        <p class="text-2xl text-pretty md:text-2xl">
            Ingénieur logiciel lillois — et fier de l'être. Je conçois des
            produits et des expériences numériques, surtout pour le web, avec
            une obsession assumée pour la qualité du code et le craft.<br />
            J'expérimente en permanence, je partage sans retenue lors de talks, et
            je suis convaincu que la connaissance prend de la valeur quand elle circule.
            Le week-end, on me trouve à supporter le LOSC ou à compiler tranquillement
            autour d'une bière bien méritée.
        </p>
    </div>
</section>

<style>
    .who-section {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        width: 100%;

        @media (min-width: 768px) {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
        }

        .who-section-picture {
            background-color: var(--color-bg-inverse);
            display: block;
            height: 480px;
            width: 100%;
            overflow: hidden;

            @media (min-width: 768px) {
                height: 720px;
            }
        }

        .who-section-content {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: flex-end;
            padding: var(--spacing-safe);
            gap: var(--spacing-100);
        }
    }
</style>
