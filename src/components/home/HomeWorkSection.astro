---
import { getCollection } from 'astro:content';
import HomeWorkSectionTile from './HomeWorkSectionTile.astro';

const allWorks = (await getCollection('work')).map((w) => w.data);
---

<section class="work-section">
    <h2 class="text-fg-subtle px-safe text-6xl font-bold">I work tech</h2>
    <div class="work-grid" role="list">
        {allWorks.map((work) => <HomeWorkSectionTile work={work} />)}
    </div>
</section>

<style>
    .work-section {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--spacing-200);
        padding-block: calc(var(--spacing-safe) * 2);

        .work-grid {
            width: 100%;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            grid-row-gap: var(--spacing-50);
            grid-column-gap: 2px;
        }
    }
</style>
